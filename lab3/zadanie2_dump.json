        "foundedYear": ">= 1900"
      }
    },
    "persons": {
      "required_fields": ["personID", "firstName", "lastName", "email"],
      "unique_fields": ["personID", "email"],
      "constraints": {
        "birthDate": "musi być w przeszłości"
      }
    },
    "excursions_hybrid": {
      "required_fields": ["excursionID", "title", "destination", "pricePerPerson"],
      "unique_fields": ["excursionID"],
      "constraints": {
        "availableSeats": "<= totalSeats",
        "averageRating": "0-5",
        "startDate": "< endDate"
      }
    }
